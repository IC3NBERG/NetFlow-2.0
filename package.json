    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed": "node scripts/seed-demo.mjs",
    "deploy": "npm run build && wrangler pages deploy dist/"
  },
  "dependencies": {
