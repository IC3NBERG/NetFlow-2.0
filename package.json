{
  "name": "netflow",
  "private": true,
  "version": "0.45.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/check-version.js && tsc && vite build",
    "preview": "vite preview",
    "lint": "node scripts/check-version.js && eslint src --report-unused-disable-directives --max-warnings 0",
